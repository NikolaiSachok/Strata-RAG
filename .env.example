# Copy to `.env` and edit. Everything has a sensible default; out of the box the engine
# runs over the SYNTHETIC sample corpus (data/sample/) with local embeddings and no key.
# You only NEED an LLM backend for: metadata enrichment, the Tier-2 rule advisor, answer
# generation, and the faithfulness judge. Retrieval + the metric table need no LLM.

# --- Corpus ------------------------------------------------------------------
# Point the engine at a real corpus. NEVER copied into the repo; its index/sidecar are
# gitignored. Defaults to the committed sample corpus.
# RAGENGINE_CORPUS_ROOT=/path/to/your/corpus-root   # parent of the source-set folders

# What counts as SIGNAL. The relevance classifier judges every file against this. Flip it
# (e.g. to a code/technical-doc RAG) and re-author corpus-rules.yaml — no code change.
# RAGEVAL_CORPUS_INTENT="user-facing application content — themes, brands, ..."

# --- LLM backend (pick ONE path) ---------------------------------------------
# Path A: raw API key. Uncomment and paste your key.
# ANTHROPIC_API_KEY=sk-ant-...
# Path B: the local `claude` CLI (Claude.ai subscription). Nothing to set — if `claude`
# is on your PATH and signed in, it's auto-detected and spends no API credits.

# Force a backend instead of auto-detecting (optional): api | cli
# RAGEVAL_LLM_BACKEND=cli
# Generation / judge / enrichment model id.
# RAGEVAL_MODEL=claude-opus-4-8

# --- Embeddings --------------------------------------------------------------
# local = sentence-transformers, no key (default). openai = OpenAI (needs key + [openai]).
# RAGEVAL_EMBEDDINGS=local
# RAGEVAL_EMBED_MODEL=all-MiniLM-L6-v2
# RAGEVAL_EMBED_DIM=384            # MUST match the model (384 MiniLM, 1536 OpenAI-small)
# OPENAI_API_KEY=sk-...            # only if RAGEVAL_EMBEDDINGS=openai

# --- Qdrant + HNSW (ANN index) ----------------------------------------------
# RAGEVAL_QDRANT_URL=http://localhost:6333
# RAGEVAL_HNSW_M=16               # graph edges/node — higher = better recall, more RAM
# RAGEVAL_HNSW_EF_CONSTRUCT=100   # build-time candidate list — higher = better graph, slower build
# RAGEVAL_HNSW_EF_SEARCH=64       # query-time candidate list — higher = better recall, slower query

# --- Hybrid retrieval / rerank / chunking -----------------------------------
# RAGEVAL_TOP_K=5                 # final chunks handed to the generator / scored in eval
# RAGEVAL_CANDIDATE_K=20          # candidates each retriever fetches before fusion
# RAGEVAL_RRF_K=60                # Reciprocal Rank Fusion constant
# RAGEVAL_USE_RERANK=true         # run the cross-encoder re-ranker over fused candidates
# RAGEVAL_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# RAGEVAL_CHUNK_SIZE=800
# RAGEVAL_CHUNK_OVERLAP=150

# --- Prompt-injection guardrails (defense-in-depth; flip one off to measure its effect) -
# RAGEVAL_GUARD_INPUT_SCAN=true        # scan retrieved chunks for injection before generation
# RAGEVAL_GUARD_SPOTLIGHT=true         # random-sentinel data fence + inert-data framing
# RAGEVAL_GUARD_OUTPUT_VALIDATE=true   # post-generation exfil / fake-cite / prompt-leak checks
# RAGEVAL_GUARD_QUARANTINE=true        # DROP (not just flag) critical-severity chunks
# RAGEVAL_GUARD_LLM_CLASSIFIER=false   # 2nd-tier LLM injection classifier (flag-only; costs a call)
